generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}


model User {
  id_user       String        @id @default(uuid())
  name          String
  email         String        @unique
  password      String
  fixed_income  Float?

  categories    Category[]
  cards         Card[]
  transactions  Transaction[]
}

model Category {
  id_category  String   @id @default(uuid())
  name         String
  type         String // expense or income

  user_id      String
  user         User     @relation(fields: [user_id], references: [id_user])

  transactions Transaction[]
}

model Card {
  id_card     String   @id @default(uuid())
  name        String
  limit       Float
  closing_day Int

  user_id     String
  user        User     @relation(fields: [user_id], references: [id_user])

  transactions Transaction[]
}

model Transaction {
  id_transaction  String   @id @default(uuid())
  title           String
  amount          Float
  date            DateTime

  type            String // expense or income
  payment_method  String // credit, debit or cash

  user_id         String
  user            User     @relation(fields: [user_id], references: [id_user])

  category_id     String
  category        Category @relation(fields: [category_id], references: [id_category])

  card_id         String?
  card            Card?    @relation(fields: [card_id], references: [id_card])
}